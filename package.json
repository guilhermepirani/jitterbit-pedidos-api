{
  "name": "jitterbit-pedidos-api",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://github.com/guilhermepirani/jitterbit-pedidos-api#readme",
  "bugs": {
    "url": "https://github.com/guilhermepirani/jitterbit-pedidos-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guilhermepirani/jitterbit-pedidos-api.git"
  },
  "license": "ISC",
  "author": "Guilherme Pirani",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "start:dev": "npm run services:up && npm run services:wait:database && npm run migrations:up && NODE_ENV=development npm start",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --coverage",
    "services:up": "docker compose --env-file .env.development up -d",
    "services:stop": "docker compose --env-file .env.development stop",
    "services:down": "docker compose --env-file .env.development down",
    "services:wait:database": "node src/storage/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m src/storage/migrations create",
    "migrations:up": "node-pg-migrate -m src/storage/migrations --envPath .env.development up",
    "prettier": "npx prettier --check . --log-level silent",
    "prettier:fix": "npx prettier --write . --log-level silent",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-xo": "^0.50.0",
    "eslint-plugin-jest": "^29.15.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "prettier": "3.8.1"
  }
}
